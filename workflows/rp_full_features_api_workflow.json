{
  "1": {
    "inputs": {
      "text": "我推开祠堂老旧的木门，门轴发出刺耳的吱呀声。祠堂里弥漫着檀香的气息，光线透过窗棂洒在牌位上。我看到一位年轻妇人正跪在蒲团上，低声祈祷。\n\n我轻轻走到她身后三步处停下，压低声音问道：「姑娘，这间祠堂供奉的是哪位先祖？」"
    },
    "class_type": "AWPTextInput",
    "_meta": {
      "title": "用户输入"
    }
  },
  "2": {
    "inputs": {
      "text": "rp-session-001"
    },
    "class_type": "AWPTextInput",
    "_meta": {
      "title": "会话ID"
    }
  },
  "3": {
    "inputs": {
      "json_text": "{\"scene\":{\"location\":\"桃花村祠堂\",\"time\":\"午后\",\"weather\":\"阴天\",\"activeHooks\":[\"祠堂禁地\",\"失踪的先祖牌位\"]},\"player\":{\"identity\":\"过路的游方道士\",\"stance\":\"谨慎试探\"},\"苏婉清\":{\"trust\":35,\"mood\":\"悲伤戒备\",\"secret\":\"先祖牌位并非失踪而是被她藏起\"},\"narrative\":{\"phase\":\"开场相遇\",\"tension\":\"低\"}}",
      "validate_json": true
    },
    "class_type": "AWPJsonInput",
    "_meta": {
